function editStation(id) {
  const s = allStations.find(x => x.StationID === id);
  if (!s) return;
  
  document.getElementById('stName').value = s.StationName || '';
  document.getElementById('stLoc').value = s.Location || '';
  document.getElementById('stBoxes').value = s.TotalBoxes || 5;
  document.getElementById('stPrice').value = s.PricePerKWh || 15;
  document.getElementById('stHours').value = s.OpenHours || '24 Hours';
  document.getElementById('stModal').classList.add('open');
}

async function deleteStation(id) {
  if (!confirm('Deactivate this station?')) return;
  
  const result = await callApi('deleteStation', { stationId: id });
  if (result.success) {
    await loadAllData();
  } else {
    alert('Error: ' + result.message);
  }
}

async function saveStation() {
  const name = document.getElementById('stName').value.trim();
  if (!name) {
    document.getElementById('stMsg').innerHTML = '<div class="msg err">Station name is required</div>';
    return;
  }
  
  const result = await callApi('addStation', {
    name: name,
    location: document.getElementById('stLoc').value,
    totalBoxes: document.getElementById('stBoxes').value || 5,
    pricePerKWh: document.getElementById('stPrice').value || 15,
    openHours: document.getElementById('stHours').value || '24 Hours'
  });
  
  if (result.success) {
    document.getElementById('stMsg').innerHTML = '<div class="msg ok">✅ Station saved!</div>';
    setTimeout(() => {
      closeModal('stModal');
      loadAllData();
    }, 900);
  } else {
    document.getElementById('stMsg').innerHTML = `<div class="msg err">${result.message}</div>`;
  }
}

