  document.getElementById('admName').value = a.FullName || '';
  document.getElementById('admPhone').value = a.Phone || '';
  document.getElementById('admEmail').value = a.Email || '';
  document.getElementById('admSt').value = a.AssignedStation || '';
  document.getElementById('admModal').classList.add('open');
}

async function deactivateAdmin(id) {
  if (!confirm('Deactivate this admin?')) return;
  
  const result = await callApi('deactivateAdmin', { adminId: id });
  if (result.success) {
    await loadAllData();
  } else {
    alert('Error: ' + result.message);
  }
}

async function saveAdmin() {
  const name = document.getElementById('admName').value.trim();
  const email = document.getElementById('admEmail').value.trim();
  const pass = document.getElementById('admPass').value;
  
  if (!name || !email || !pass) {
    document.getElementById('admMsg').innerHTML = '<div class="msg err">Name, email and password required</div>';
    return;
  }
  
  const result = await callApi('createAdmin', {
    fullName: name,
    phone: document.getElementById('admPhone').value,
    email: email,
    password: pass,
    assignedStation: document.getElementById('admSt').value || ''
  });
  
  if (result.success) {
    document.getElementById('admMsg').innerHTML = '<div class="msg ok">✅ Admin created!</div>';
    setTimeout(() => {
      closeModal('admModal');
      loadAllData();
    }, 900);
  } else {
    document.getElementById('admMsg').innerHTML = `<div class="msg err">${result.message}</div>`;
  }
}

