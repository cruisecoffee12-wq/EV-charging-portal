<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EV Charge — Owner Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#060810;--surface:#0e1520;--surface2:#141f30;--surface3:#1b2a40;
  --border:#1c2e46;--accent:#00e5b8;--accent2:#3d8eff;--gold:#f5a623;
  --danger:#ff3d57;--warning:#ffab00;--text:#dce8f5;--text2:#506a8a;--text3:#8aa8c8;
  --radius:13px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);display:flex;flex-direction:column;min-height:100vh;}

/* NAV */
nav{background:rgba(14,21,32,.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);height:66px;display:flex;align-items:center;padding:0 26px;gap:16px;position:sticky;top:0;z-index:100;flex-shrink:0;}
.nav-logo{display:flex;align-items:center;gap:12px;}
.crown{width:40px;height:40px;background:linear-gradient(135deg,var(--gold),#e67e00);border-radius:12px;display:grid;place-items:center;font-size:20px;box-shadow:0 0 20px rgba(245,166,35,.2);}
.brand{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;}
.brand em{color:var(--gold);font-style:normal;}
.owner-badge{background:rgba(245,166,35,.1);border:1px solid rgba(245,166,35,.25);color:var(--gold);padding:5px 14px;border-radius:20px;font-size:12px;font-weight:700;margin-left:auto;}
.btn-out{background:none;border:none;color:var(--text2);font-size:13px;cursor:pointer;padding:6px 10px;border-radius:8px;transition:.2s;}
.btn-out:hover{color:var(--danger);}

/* LAYOUT */
.layout{display:flex;flex:1;}
.sidebar{width:230px;background:var(--surface);border-right:1px solid var(--border);padding:22px 10px;flex-shrink:0;position:sticky;top:66px;height:calc(100vh - 66px);overflow-y:auto;}
.si-sec{font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:var(--text2);padding:0 12px;margin:16px 0 8px;}
.si-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;cursor:pointer;color:var(--text2);font-size:14px;font-weight:500;margin-bottom:2px;transition:.2s;}
.si-item:hover{background:rgba(245,166,35,.08);color:var(--gold);}
.si-item.active{background:rgba(245,166,35,.1);color:var(--gold);}
.si-icon{font-size:17px;width:22px;text-align:center;}

.main{flex:1;padding:28px;overflow-y:auto;min-width:0;}
.page{display:none;animation:fadeUp .3s ease;}
.page.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

/* HEADINGS */
.ph{margin-bottom:24px;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;}
.ph-left .pt{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;letter-spacing:-.4px;}
.ph-left .ps{color:var(--text2);font-size:14px;margin-top:4px;}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:14px;margin-bottom:24px;}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;position:relative;overflow:hidden;transition:border-color .2s;}
.kpi:hover{border-color:rgba(245,166,35,.3);}
.kpi::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;}
.kpi:nth-child(1)::after{background:var(--accent);}
.kpi:nth-child(2)::after{background:var(--gold);}
.kpi:nth-child(3)::after{background:var(--accent2);}
.kpi:nth-child(4)::after{background:var(--danger);}
.kpi:nth-child(5)::after{background:var(--warning);}
.kpi-lbl{font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--text2);margin-bottom:10px;}
.kpi-val{font-family:'Syne',sans-serif;font-size:32px;font-weight:800;line-height:1;}
.kpi-sub{font-size:12px;color:var(--text2);margin-top:5px;}
.kpi-ico{position:absolute;right:16px;top:16px;font-size:26px;opacity:.15;}

/* TWO COL */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
@media(max-width:900px){.two-col{grid-template-columns:1fr;}}

/* CHART CARD */
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;}
.cc-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;margin-bottom:18px;}
.bars{display:flex;align-items:flex-end;gap:8px;height:120px;border-bottom:1px solid var(--border);}
.bar-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;}
.bar{width:100%;border-radius:5px 5px 0 0;min-height:3px;background:linear-gradient(to top,var(--gold),#e69b00);}
.bar-v{font-size:10px;color:var(--gold);font-weight:700;}
.bar-l{font-size:9px;color:var(--text2);white-space:nowrap;}

/* PEAK HOUR GRID */
.peak-grid{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;}
.ph-item{background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:10px 14px;text-align:center;min-width:80px;}
.ph-count{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:var(--gold);}
.ph-time{font-size:11px;color:var(--text2);margin-top:2px;}

/* TABLE */
.tbl-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:20px;}
table{width:100%;border-collapse:collapse;}
th{background:var(--surface2);padding:11px 16px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--text2);font-weight:700;}
td{padding:13px 16px;border-top:1px solid var(--border);font-size:13px;vertical-align:middle;}
tr:hover td{background:rgba(255,255,255,.02);}
.mono{font-family:monospace;font-size:12px;}

/* PILLS */
.pill{display:inline-block;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.pill-Active{background:rgba(0,229,184,.12);color:var(--accent);border:1px solid rgba(0,229,184,.25);}
.pill-Inactive{background:rgba(255,61,87,.1);color:var(--danger);border:1px solid rgba(255,61,87,.2);}
.pill-Booked{background:rgba(61,142,255,.15);color:var(--accent2);}
.pill-CheckedIn{background:rgba(0,229,184,.15);color:var(--accent);}
.pill-Completed{background:rgba(93,122,158,.1);color:var(--text3);}
.pill-Cancelled{background:rgba(255,61,87,.1);color:var(--danger);}

/* BUTTONS */
.btn{border:none;border-radius:9px;padding:9px 16px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;cursor:pointer;transition:.2s;letter-spacing:.2px;}
.btn-gold{background:linear-gradient(135deg,var(--gold),#e67e00);color:#1a0a00;}
.btn-gold:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-primary{background:linear-gradient(135deg,var(--accent),#00c4a0);color:#001a12;}
.btn-primary:hover{filter:brightness(1.1);}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--text);}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);}
.btn-danger{background:rgba(255,61,87,.12);color:var(--danger);border:1px solid rgba(255,61,87,.2);}
.btn-danger:hover{background:rgba(255,61,87,.25);}
.btn-sm{padding:5px 11px;font-size:11px;border-radius:7px;}

/* FORM / MODAL */
input,select,textarea{background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:10px 13px;color:var(--text);font-size:13px;font-family:inherit;outline:none;transition:.2s;}
input:focus,select:focus,textarea:focus{border-color:var(--gold);}
input::placeholder,textarea::placeholder{color:var(--text2);}
select option{background:var(--surface);}
.fg{margin-bottom:13px;}
.fg label{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.6px;color:var(--text3);font-weight:700;margin-bottom:6px;}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

.overlay{position:fixed;inset:0;background:rgba(0,0,0,.8);backdrop-filter:blur(8px);z-index:200;display:none;align-items:center;justify-content:center;padding:16px;}
.overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:22px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.6);animation:slideUp .3s cubic-bezier(.34,1.56,.64,1);}
@keyframes slideUp{from{transform:translateY(30px);opacity:0;}to{transform:none;opacity:1;}}
.mhd{padding:24px 24px 0;display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
.mtitle{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;}
.mx{background:none;border:none;color:var(--text2);font-size:22px;cursor:pointer;width:32px;height:32px;display:grid;place-items:center;border-radius:8px;transition:.2s;}
.mx:hover{background:var(--surface2);}
.mbody{padding:0 24px 24px;}
.msg{padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:12px;}
.msg.ok{background:rgba(0,229,184,.1);border:1px solid rgba(0,229,184,.25);color:var(--accent);}
.msg.err{background:rgba(255,61,87,.1);border:1px solid rgba(255,61,87,.25);color:#ff7087;}

/* REVENUE SECTION */
.rev-top{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;max-width:600px;margin-bottom:20px;}
.rv{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;}
.rv-lbl{font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--text2);margin-bottom:8px;}
.rv-val{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--gold);}

/* LOADING */
.loading{display:flex;gap:7px;justify-content:center;padding:40px;}
.dot{width:8px;height:8px;border-radius:50%;background:var(--gold);animation:bop .7s infinite alternate;}
.dot:nth-child(2){animation-delay:.18s;}.dot:nth-child(3){animation-delay:.36s;}
@keyframes bop{to{transform:translateY(-12px);opacity:.3;}}
.empty{text-align:center;padding:40px;color:var(--text2);}

@media(max-width:768px){.sidebar{display:none;}.main{padding:16px;}.fr{grid-template-columns:1fr;}}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">
    <div class="crown">👑</div>
    <div class="brand">EV<em>Charge</em> <span style="color:var(--text2);font-weight:400;font-size:14px">Owner</span></div>
  </div>
  <div class="owner-badge">👑 Super Admin</div>
  <button class="btn-out" onclick="logout()">Logout</button>
</nav>

<div class="layout">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="si-sec">Overview</div>
    <div class="si-item active" onclick="nav(this,'pgDash')"><span class="si-icon">📊</span>Dashboard</div>
    <div class="si-item" onclick="nav(this,'pgAllBk')"><span class="si-icon">📋</span>All Bookings</div>
    <div class="si-sec">Management</div>
    <div class="si-item" onclick="nav(this,'pgStations')"><span class="si-icon">🏪</span>Stations</div>
    <div class="si-item" onclick="nav(this,'pgAdmins')"><span class="si-icon">👤</span>Admins</div>
    <div class="si-item" onclick="nav(this,'pgCustomers')"><span class="si-icon">🚗</span>Customers</div>
    <div class="si-sec">Finance</div>
    <div class="si-item" onclick="nav(this,'pgRevenue')"><span class="si-icon">💰</span>Revenue</div>
    <div class="si-item" onclick="nav(this,'pgReports')"><span class="si-icon">📈</span>Reports</div>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- ── DASHBOARD ── -->
    <div class="page active" id="pgDash">
      <div class="ph"><div class="ph-left"><div class="pt">Owner Dashboard</div><div class="ps">Complete EV charging network at a glance</div></div></div>
      <div class="loading" id="dashLoading"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
      <div class="kpi-grid" id="dashKPI"></div>
      <div class="two-col">
        <div class="chart-card">
          <div class="cc-title">💰 Revenue by Station</div>
          <div class="bars" id="stRevBars"></div>
          <div style="margin-top:12px;display:flex;flex-direction:column;gap:6px" id="stRevLegend"></div>
        </div>
        <div class="chart-card">
          <div class="cc-title">🕐 Peak Booking Hours</div>
          <div class="peak-grid" id="peakGrid"></div>
        </div>
      </div>
      <div class="chart-card" style="margin-bottom:20px">
        <div class="cc-title">📅 Monthly Revenue Trend (2026)</div>
        <div class="bars" id="monthBars"></div>
      </div>
    </div>

    <!-- ── ALL BOOKINGS ── -->
    <div class="page" id="pgAllBk">
      <div class="ph"><div class="ph-left"><div class="pt">All Bookings</div><div class="ps">Network-wide booking records</div></div></div>
      <div class="loading" id="allBkLoading"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>Booking ID</th><th>Customer</th><th>Station</th><th>Date</th><th>Time</th><th>Cost</th><th>Status</th></tr></thead>
          <tbody id="allBkBody"></tbody>
