      </div>
      <div class="loading" id="stationsLoading"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>Station Name</th><th>Location</th><th>Boxes</th><th>Price/kWh</th><th>Hours</th><th>Admin</th><th>Status</th><th>Actions</th></tr></thead>
