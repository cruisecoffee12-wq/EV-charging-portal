        </table>
      </div>
    </div>

    <!-- ── ADMINS ── -->
    <div class="page" id="pgAdmins">
      <div class="ph">
        <div class="ph-left"><div class="pt">Admin Management</div><div class="ps">Station administrators</div></div>
        <button class="btn btn-primary" onclick="openModal('admModal')">+ Add Admin</button>
      </div>
      <div class="loading" id="adminsLoading"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>Name</th><th>Email</th><th>Assigned Station</th><th>Status</th><th>Actions</th></tr></thead>
          <tbody id="admBody"></tbody>
        </table>
      </div>
    </div>

    <!-- ── CUSTOMERS ── -->
    <div class="page" id="pgCustomers">
      <div class="ph"><div class="ph-left"><div class="pt">Customer Accounts</div><div class="ps" id="customerCount"></div></div></div>
      <div class="loading" id="customersLoading"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Vehicle</th><th>Battery</th><th>Plate</th><th>Bookings</th></tr></thead>
          <tbody id="custBody"></tbody>
        </table>
      </div>
    </div>

    <!-- ── REVENUE ── -->
    <div class="page" id="pgRevenue">
      <div class="ph"><div class="ph-left"><div class="pt">Revenue Overview</div><div class="ps">Financial performance across all stations</div></div>
        <button class="btn btn-outline" onclick="exportCSV()">⬇ Export CSV</button>
      </div>
      <div class="loading" id="revenueLoading"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
      <div class="rev-top" id="revenueTop"></div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>Station</th><th>Total Revenue</th><th>Bookings</th><th>Avg/Booking</th></tr></thead>
          <tbody id="revBody"></tbody>
        </table>
      </div>
    </div>

    <!-- ── REPORTS ── -->
    <div class="page" id="pgReports">
      <div class="ph"><div class="ph-left"><div class="pt">Analytics & Reports</div><div class="ps">Network performance deep dive</div></div>
        <button class="btn btn-outline" onclick="exportCSV()">⬇ Export CSV</button>
      </div>
      <div class="loading" id="reportsLoading"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>
      <div class="kpi-grid" id="reportKPI"></div>
      <div class="two-col">
        <div class="chart-card">
          <div class="cc-title">📊 Bookings per Station</div>
          <div class="bars" id="bkPerSt"></div>
        </div>
        <div class="chart-card">
          <div class="cc-title">💳 Payment Methods</div>
          <div style="margin-top:12px;display:flex;flex-direction:column;gap:10px">
            <div style="display:flex;justify-content:space-between;align-items:center">
              <span style="font-size:13px">📱 Telebirr</span>
              <div style="display:flex;align-items:center;gap:10px">
                <div style="width:160px;height:8px;background:var(--surface3);border-radius:4px;overflow:hidden"><div style="height:100%;width:74%;background:var(--gold);border-radius:4px"></div></div>
                <span style="font-size:13px;font-weight:700;color:var(--gold)">74%</span>
              </div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <span style="font-size:13px">💵 Pay at Station</span>
              <div style="display:flex;align-items:center;gap:10px">
                <div style="width:160px;height:8px;background:var(--surface3);border-radius:4px;overflow:hidden"><div style="height:100%;width:26%;background:var(--accent2);border-radius:4px"></div></div>
                <span style="font-size:13px;font-weight:700;color:var(--accent2)">26%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- STATION MODAL -->
<div class="overlay" id="stModal">
  <div class="modal">
    <div class="mhd"><div class="mtitle">Add New Station</div><button class="mx" onclick="closeModal('stModal')">✕</button></div>
    <div class="mbody">
      <div id="stMsg"></div>
      <div class="fr">
        <div class="fg"><label>Station Name</label><input id="stName" placeholder="Bole EV Hub"/></div>
        <div class="fg"><label>Location</label><input id="stLoc" placeholder="Bole, Addis Ababa"/></div>
      </div>
      <div class="fr">
        <div class="fg"><label>Total Boxes</label><input type="number" id="stBoxes" placeholder="5" min="1"/></div>
        <div class="fg"><label>Price / kWh (ETB)</label><input type="number" id="stPrice" placeholder="15"/></div>
      </div>
      <div class="fg"><label>Operating Hours</label><input id="stHours" placeholder="06:00 AM – 10:00 PM"/></div>
      <button class="btn btn-gold" style="width:100%;padding:13px;margin-top:6px" onclick="saveStation()">Save Station</button>
    </div>
  </div>
</div>

<!-- ADMIN MODAL -->
<div class="overlay" id="admModal">
  <div class="modal">
    <div class="mhd"><div class="mtitle">Create Admin Account</div><button class="mx" onclick="closeModal('admModal')">✕</button></div>
    <div class="mbody">
      <div id="admMsg"></div>
      <div class="fr">
        <div class="fg"><label>Full Name</label><input id="admName" placeholder="Admin Name"/></div>
        <div class="fg"><label>Phone</label><input id="admPhone" placeholder="+251..."/></div>
      </div>
      <div class="fg"><label>Email</label><input id="admEmail" type="email" placeholder="admin@station.com"/></div>
      <div class="fg"><label>Password</label><input type="password" id="admPass" placeholder="Secure password"/></div>
      <div class="fg"><label>Assign to Station</label>
        <select id="admSt">
          <option value="">— Select Station —</option>
        </select>
      </div>
      <button class="btn btn-primary" style="width:100%;padding:13px;margin-top:6px" onclick="saveAdmin()">Create Admin</button>
    </div>
  </div>
</div>

<script>
// === CONFIGURATION ===
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxjifBEB6MwNpdVmM6xjTdNa6ACZBoHqNEkBnSlj4buCfJuwtkXgivtPMLnqy3I5q_q/exec';

// Global state
let allStations = [];
let allAdmins = [];
let allCustomers = [];
let allBookings = [];

// ──────────────────────────────────────────────────────
// API CALLS
// ──────────────────────────────────────────────────────
async function callApi(action, data = {}) {
  try {
    const response = await fetch(SCRIPT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action, data })
    });
    return await response.json();
  } catch (error) {
    console.error('API call failed:', error);
    return { success: false, message: 'Network error: ' + error.message };
  }
}

// ──────────────────────────────────────────────────────
// AUTH / LOGIN
// ──────────────────────────────────────────────────────
async function doOwnerLogin() {
  const result = await callApi('ownerSignIn', {
    email: 'owner@evcharge.com',
    password: 'Owner@123'
  });
  
  if (!result.success) {
    alert('Owner login failed. Using mock data for demo.');
  }
  
  await loadAllData();
}

// ──────────────────────────────────────────────────────
// LOAD ALL DATA
// ──────────────────────────────────────────────────────
async function loadAllData() {
  document.getElementById('dashLoading').style.display = 'flex';
  
  // Load stations
  const stationsResult = await callApi('getAllStations');
  if (stationsResult.success) {
    allStations = stationsResult.stations || [];
    document.getElementById('stationCount').textContent = `${allStations.length} stations across Addis Ababa`;
  }
  
  // Load admins
  const adminsResult = await callApi('getAllAdmins');
  if (adminsResult.success) {
    allAdmins = adminsResult.admins || [];
  }
  
  // Load customers (from Customers sheet)
  // This would need a getCustomers API - for now using mock
  
  // Load bookings
  const bookingsResult = await callApi('getAllBookings');
  if (bookingsResult.success) {
    allBookings = bookingsResult.bookings || [];
  }
  
  // Load dashboard data
  const dashResult = await callApi('getOwnerDashboard');
  if (dashResult.success) {
    renderDashboard(dashResult);
  }
  
  // Render all sections
  renderStations();
  renderAdmins();
  renderCustomers();
  renderAllBookings();
  renderRevenue();
  renderReports();
  
  // Populate station dropdown in admin modal
  const admSt = document.getElementById('admSt');
  if (admSt) {
    admSt.innerHTML = '<option value="">— Select Station —</option>' + 
      allStations.map(s => `<option value="${s.StationID}">${s.StationName}</option>`).join('');
  }
  
  document.getElementById('dashLoading').style.display = 'none';
}

