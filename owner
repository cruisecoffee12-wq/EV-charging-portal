function renderStations() {
  document.getElementById('stationsLoading').style.display = 'none';
  const tbody = document.getElementById('stBody');
  
  if (!allStations || allStations.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8" class="empty">No stations found</td></tr>';
    return;
