function renderDashboard(data) {
  document.getElementById('dashKPI').innerHTML = `
    <div class="kpi"><div class="kpi-lbl">Total Stations</div><div class="kpi-val">${data.totalStations || 0}</div><div class="kpi-sub">Active</div><div class="kpi-ico">🏪</div></div>
    <div class="kpi"><div class="kpi-lbl">Total Revenue</div><div class="kpi-val" style="font-size:22px">ETB ${(data.totalRevenue || 0).toLocaleString()}</div><div class="kpi-sub">All time</div><div class="kpi-ico">💰</div></div>
    <div class="kpi"><div class="kpi-lbl">This Month</div><div class="kpi-val" style="font-size:22px">ETB ${(data.monthlyRevenue || 0).toLocaleString()}</div><div class="kpi-sub">Current month</div><div class="kpi-ico">📅</div></div>
    <div class="kpi"><div class="kpi-lbl">Customers</div><div class="kpi-val">${data.totalCustomers || 0}</div><div class="kpi-sub">Registered</div><div class="kpi-ico">👥</div></div>
    <div class="kpi"><div class="kpi-lbl">Total Bookings</div><div class="kpi-val">${data.totalBookings || 0}</div><div class="kpi-sub">All time</div><div class="kpi-ico">📋</div></div>
  `;
  
  // Revenue per station bars
  const revenuePerStation = data.revenuePerStation || [];
  const maxRev = Math.max(...revenuePerStation.map(s => s.Revenue), 1);
  
  document.getElementById('stRevBars').innerHTML = revenuePerStation.map(s => `
    <div class="bar-item">
      <div class="bar-v">ETB ${Math.round(s.Revenue/1000)}k</div>
      <div class="bar" style="height:${Math.round((s.Revenue/maxRev)*100)}px"></div>
      <div class="bar-l">${s.StationName?.split(' ')[0] || ''}</div>
    </div>
  `).join('');
  
  document.getElementById('stRevLegend').innerHTML = revenuePerStation.map(s => `
    <div style="display:flex;justify-content:space-between;font-size:12px;padding:3px 0">
      <span style="color:var(--text3)">${s.StationName || ''}</span>
      <span style="font-weight:600;color:var(--gold)">ETB ${(s.Revenue/1000).toFixed(1)}k</span>
    </div>
  `).join('');
  
  // Peak hours
  const peakHours = data.peakHours || {};
  const peakArray = Object.entries(peakHours).map(([t,c]) => ({t,c})).sort((a,b) => b.c - a.c).slice(0,8);
  const maxPeak = Math.max(...peakArray.map(p => p.c), 1);
  
  document.getElementById('peakGrid').innerHTML = peakArray.map(p => `
    <div class="ph-item" style="border-color:${p.c === maxPeak ? 'rgba(245,166,35,.4)' : ''}">
      <div class="ph-count" style="color:${p.c === maxPeak ? 'var(--gold)' : 'var(--text3)'}">${p.c}</div>
      <div class="ph-time">${p.t}</div>
    </div>
  `).join('');
  
  // Monthly trend
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const monthlyData = months.map((m,i) => ({
    m, v: i < 3 ? Math.random() * 50000 + 30000 : 0
  }));
  
  const maxMonth = Math.max(...monthlyData.map(d => d.v), 1);
  document.getElementById('monthBars').innerHTML = monthlyData.map(d => `
    <div class="bar-item">
      ${d.v ? `<div class="bar-v">${Math.round(d.v/1000)}k</div>` : '<div class="bar-v" style="color:var(--text2)">—</div>'}
      <div class="bar" style="height:${Math.max(2, Math.round((d.v/maxMonth)*100))}px;background:${d.v ? 'linear-gradient(to top,var(--gold),#e69b00)' : 'var(--surface3)'}"></div>
      <div class="bar-l">${d.m}</div>
    </div>
  `).join('');
}
