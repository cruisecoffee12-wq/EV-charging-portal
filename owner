function exportCSV() {
  const rows = [['Station', 'Revenue (ETB)', 'Bookings'], ...allStations.map(s => [s.StationName, s.revenue || 0, s.bookings || 0])];
  const csv = rows.map(r => r.join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download = 'ev_report_' + new Date().toISOString().slice(0, 10) + '.csv';
  a.click();
}

